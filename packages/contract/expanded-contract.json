  "editPolicies": {
    "description": "Safety rules that constrain future model-generated changes.",
    "globalDefaults": {
      "clientCanComment": true,
      "clientCanEdit": false,
      "clientCanGeneratePatch": false,
      "clientCanPublish": false,
      "ownerApprovalRequired": true,
      "modelOutputTrusted": false,
      "publishAllowedByDefault": false
    },
    "riskLevels": {
      "low": [
        "copyChange",
        "ctaLabelChange",
        "visualVariantChange",
        "spacingDensityChange",
        "sectionToneChange"
      ],
      "medium": [
        "reorderSection",
        "addSection",
        "removeSection",
        "replaceImage",
        "editHref"
      ],
      "high": [
        "changeFormDestination",
        "changeAnalytics",
        "changePricing",
        "changeLegalText",
        "injectScript"
      ],
      "blocked": [
        "javascriptHref",
        "hiddenDataCapture",
        "secretExposure",
        "unapprovedTracking",
        "unauthorizedPublish"
      ]
    },
    "safeOperations": {
      "copyChange": {
        "description": "Change visible copy without changing links, destinations, forms, legal, analytics, or behavior.",
        "allowedTargets": [
          "Heading.text",
          "Text.text",
          "Button.label",
          "Badge.label",
          "FAQItem.question",
          "FAQItem.answer",
          "FeatureCard.title",
          "FeatureCard.description"
        ]
      },
      "visualEmphasisChange": {
        "description": "Change emphasis through variants and tokens, not arbitrary CSS.",
        "allowedTargets": [
          "Section.variant",
          "Card.variant",
          "Button.variant",
          "Badge.variant",
          "spacing.density",
          "shadow.role",
          "radius.role"
        ]
      },
      "campaignAdaptation": {
        "description": "Adapt copy and section emphasis to a new audience, offer, or channel while preserving brand and conversion mechanics.",
        "allowedTargets": [
          "contentStrategy.audience",
          "contentStrategy.offer",
          "Hero",
          "Benefits",
          "FeatureGrid",
          "FAQ",
          "FinalCTA"
        ],
        "preserveByDefault": [
          "form.destination",
          "analytics",
          "pricing.values",
          "legal",
          "brand.tokens"
        ]
      }
    }
  },
  "migrationPolicy": {
    "description": "How arbitrary source pages are normalized into the canonical contract.",
    "goal": "faithfulSemanticReconstruction",
    "preserve": [
      "brandFeel",
      "offer",
      "headlineHierarchy",
      "primaryCTA",
      "trustSignals",
      "forms",
      "analyticsDetection",
      "SEOIntent",
      "importantAssets"
    ],
    "normalize": [
      "layoutStructure",
      "spacing",
      "componentShapes",
      "buttonStyles",
      "cardStyles",
      "sectionRoles",
      "copySlots"
    ],
    "doNotPromise": [
      "pixelPerfectClone",
      "arbitraryAnimationParity",
      "platformSpecificPluginBehavior",
      "unverifiedThirdPartyIntegrationBehavior"
    ],
    "classificationTargets": [
      "sectionRole",
      "contentStrategySlot",
      "brandTokenRole",
      "componentRecipe",
      "safeEditPolicy"
    ]
  },
  "intentMapping": {
    "description": "Natural-language requests should resolve to semantic operations before touching generated code.",
    "examples": {
      "make this more direct": {
        "preferredOperation": "copyChange",
        "preferredTargets": [
          "Hero.headline",
          "Hero.subheadline",
          "FinalCTA.heading",
          "Button.label"
        ],
        "avoid": [
          "layoutChange",
          "brandTokenChange"
        ]
      },
      "make this stand out more": {
        "preferredOperation": "visualEmphasisChange",
        "preferredTargets": [
          "Section.variant",
          "Card.variant",
          "Button.variant",
          "Badge.variant"
        ],
        "avoid": [
          "arbitraryColorChange",
          "newCustomCSS"
        ]
      },
      "make this page for dentists": {
        "preferredOperation": "campaignAdaptation",
        "preferredTargets": [
          "contentStrategy.audience",
          "Hero",
          "Benefits",
          "FeatureGrid",
          "FAQ",
          "FinalCTA"
        ],
        "preserve": [
          "brand",
          "layout",
          "formDestination",
          "analytics"
        ]
      },
      "make it premium": {
        "preferredOperation": "visualEmphasisChange",
        "preferredTargets": [
          "brand.voice",
          "Section.variant",
          "Card.variant",
          "spacing.density",
          "shadow.role",
          "typography.textRoles"
        ],
        "avoid": [
          "randomGradient",
          "excessiveAnimation",
          "unapprovedPricingChange"
        ]
      }
    }
  },
  "extensionModel": {
    "description": "The contract is intentionally small. New recipes, sections, renderers, and policies can be added without changing the foundation.",
    "allowedExtensions": [
      "newSectionRecipe",
      "newBlockRecipe",
      "newElementVariant",
      "newRenderer",
      "newDeployAdapter",
      "newInferenceProvider",
      "newSafetyPolicy"
    ],
    "rendererTargets": [
      "reactTailwind",
      "astro",
      "staticHtml",
      "next",
      "email"
    ]
  }
}