{
  "$schema": "https://stitch.dev/schemas/design-contract.v0.json",
  "kind": "StitchDesignContract",
  "version": "0.1.0",
  "name": "Stitch Canonical Campaign Design Contract",
  "purpose": "Normalize migrated marketing pages into a semantic, brand-aware, campaign-oriented page model that can be safely edited, regenerated, reviewed, and deployed.",
  "principles": [
    "Semantic before visual",
    "Spec before code",
    "Brand-specific expression through canonical roles",
    "Small vocabulary, infinite composition",
    "Every editable object declares safe operations",
    "Client feedback is untrusted until owner-approved",
    "Model output is untrusted until validated",
    "Preserve intent, not arbitrary implementation details"
  ],
  "hierarchy": [
    "brand",
    "page",
    "section",
    "block",
    "element",
    "token"
  ],
  "canonicalEditTargetOrder": [
    "contentStrategy",
    "campaignPageSpec",
    "sectionRecipe",
    "componentRecipe",
    "designToken",
    "generatedCode"
  ],
  "brand": {
    "description": "The portable visual and verbal identity extracted during migration or defined by the owner.",
    "tokens": {
      "color": {
        "description": "Semantic color roles. Raw colors are mapped into these roles during migration.",
        "roles": [
          "canvas",
          "surface",
          "surfaceAlt",
          "surfaceElevated",
          "surfaceInverse",
          "text",
          "textMuted",
          "textSubtle",
          "textInverse",
          "border",
          "borderStrong",
          "brand",
          "brandContrast",
          "accent",
          "accentContrast",
          "success",
          "warning",
          "danger"
        ]
      },
      "typography": {
        "description": "Semantic type roles and scale. Font choices belong to brand; page sections reference roles.",
        "fontRoles": [
          "display",
          "heading",
          "body",
          "label",
          "mono"
        ],
        "textRoles": [
          "hero",
          "h1",
          "h2",
          "h3",
          "lead",
          "body",
          "small",
          "caption",
          "button",
          "eyebrow"
        ]
      },
      "spacing": {
        "description": "Spacing should be edited through intent roles rather than arbitrary values.",
        "scale": [
          "none",
          "xs",
          "sm",
          "md",
          "lg",
          "xl",
          "2xl",
          "3xl"
        ],
        "roles": [
          "pagePadding",
          "sectionPadding",
          "sectionGap",
          "blockGap",
          "itemGap",
          "inlineGap"
        ],
        "density": [
          "compact",
          "comfortable",
          "spacious"
        ]
      },
      "layout": {
        "description": "Canonical layout constraints shared by sections and blocks.",
        "container": [
          "narrow",
          "default",
          "wide",
          "full"
        ],
        "alignment": [
          "start",
          "center",
          "end",
          "split"
        ],
        "responsiveBehavior": [
          "stackOnMobile",
          "preserveGrid",
          "hideSecondaryOnMobile",
          "prioritizeContent",
          "prioritizeMedia"
        ]
      },
      "radius": {
        "description": "Shape roles for common UI elements.",
        "roles": [
          "none",
          "sm",
          "md",
          "lg",
          "xl",
          "full",
          "button",
          "card",
          "media",
          "input"
        ]
      },
      "shadow": {
        "description": "Elevation roles, not arbitrary shadow values.",
        "roles": [
          "none",
          "sm",
          "md",
          "lg",
          "card",
          "floating"
        ]
      },
      "border": {
        "description": "Border roles for structure and emphasis.",
        "roles": [
          "none",
          "subtle",
          "default",
          "strong",
          "brand"
        ]
      },
      "motion": {
        "description": "Motion is conservative by default for campaign pages.",
        "roles": [
          "none",
          "subtle",
          "standard",
          "expressive"
        ],
        "defaultPolicy": "subtle"
      }
    },
    "imagery": {
      "description": "Brand-level image guidance.",
      "roles": [
        "product",
        "people",
        "abstract",
        "illustration",
        "screenshot",
        "logo",
        "icon",
        "background"
      ],
      "style": [
        "minimal",
        "editorial",
        "technical",
        "playful",
        "premium",
        "friendly",
        "bold"
      ]
    },
    "voice": {
      "description": "Verbal identity used by content strategy and campaign variants.",
      "dimensions": {
        "formality": [
          "casual",
          "neutral",
          "formal"
        ],
        "energy": [
          "calm",
          "confident",
          "urgent",
          "bold"
        ],
        "clarity": [
          "plainspoken",
          "specific",
          "technical",
          "aspirational"
        ],
        "personality": [
          "friendly",
          "expert",
          "premium",
          "playful",
          "direct"
        ]
      }
    }
  },
  "contentStrategy": {
    "description": "The campaign meaning layer. This is what lets Stitch generate and optimize landing pages without treating copy as random text.",
    "pageGoals": [
      "lead",
      "signup",
      "bookCall",
      "purchase",
      "download",
      "waitlist",
      "awareness",
      "eventRegistration"
    ],
    "audience": {
      "fields": [
        "segment",
        "role",
        "industry",
        "companySize",
        "awarenessLevel",
        "primaryPain",
        "desiredOutcome",
        "objections",
        "buyingStage"
      ],
      "awarenessLevels": [
        "unaware",
        "problemAware",
        "solutionAware",
        "productAware",
        "mostAware"
      ],
      "buyingStages": [
        "exploring",
        "comparing",
        "readyToAct",
        "returning"
      ]
    },
    "offer": {
      "fields": [
        "promise",
        "mechanism",
        "deliverable",
        "incentive",
        "urgency",
        "riskReversal",
        "primaryCTA",
        "secondaryCTA"
      ],
      "offerTypes": [
        "freeAudit",
        "demo",
        "consultation",
        "trial",
        "download",
        "newsletter",
        "purchase",
        "event",
        "waitlist"
      ]
    },
    "messagePrimitives": [
      "audience",
      "pain",
      "promise",
      "outcome",
      "mechanism",
      "differentiator",
      "proof",
      "objection",
      "riskReversal",
      "urgency",
      "cta",
      "trust"
    ],
    "persuasionFlow": [
      {
        "stage": "attention",
        "purpose": "Make the visitor understand relevance immediately.",
        "commonSections": [
          "Hero"
        ]
      },
      {
        "stage": "relevance",
        "purpose": "Show that the page understands the visitor's problem or goal.",
        "commonSections": [
          "Problem",
          "Benefits"
        ]
      },
      {
        "stage": "desire",
        "purpose": "Explain the outcome, mechanism, and value.",
        "commonSections": [
          "FeatureGrid",
          "HowItWorks",
          "Offer"
        ]
      },
      {
        "stage": "trust",
        "purpose": "Reduce perceived risk with proof.",
        "commonSections": [
          "LogoCloud",
          "Testimonials",
          "Stats",
          "FAQ"
        ]
      },
      {
        "stage": "action",
        "purpose": "Ask for the conversion clearly.",
        "commonSections": [
          "Pricing",
          "FinalCTA",
          "Footer"
        ]
      }
    ],
    "copyIntents": [
      "makeClearer",
      "makeShorter",
      "makeMoreSpecific",
      "makeMoreDirect",
      "makeMorePremium",
      "makeMoreFriendly",
      "makeMoreUrgent",
      "makeMoreTrustworthy",
      "adaptToAudience",
      "adaptToChannel",
      "increaseConversionIntent"
    ],
    "campaignChannels": [
      "googleAds",
      "linkedinAds",
      "metaAds",
      "email",
      "organicSearch",
      "partner",
      "event",
      "salesOutbound",
      "direct"
    ]
  },
  "page": {
    "description": "A campaign page is a goal-oriented sequence of semantic sections rendered through brand tokens.",
    "requiredFields": [
      "id",
      "title",
      "slug",
      "goal",
      "brand",
      "sections",
      "seo"
    ],
    "optionalFields": [
      "audience",
      "offer",
      "campaign",
      "integrations",
      "analytics",
      "experiments"
    ],
    "allowedOperations": [
      "editCopy",
      "editToken",
      "changeVariant",
      "reorderSections",
      "addSection",
      "removeSection",
      "createVariant",
      "updateSEO"
    ],
    "protectedOperations": [
      "changeAnalyticsProvider",
      "changeFormDestination",
      "changePaymentDestination",
      "injectScript",
      "modifyConsentLanguage"
    ]
  },
  "layoutPrimitives": {
    "description": "Minimal composable layout vocabulary.",
    "primitives": {
      "Section": {
        "purpose": "Top-level page region with semantic role.",
        "slots": [
          "header",
          "body",
          "footer"
        ],
        "variants": [
          "default",
          "muted",
          "brand",
          "contrast",
          "dark"
        ]
      },
      "Container": {
        "purpose": "Horizontal content constraint.",
        "variants": [
          "narrow",
          "default",
          "wide",
          "full"
        ]
      },
      "Stack": {
        "purpose": "Vertical rhythm.",
        "variants": [
          "compact",
          "comfortable",
          "spacious"
        ]
      },
      "Grid": {
        "purpose": "Repeated item layout.",
        "variants": [
          "twoColumn",
          "threeColumn",
          "fourColumn",
          "autoFit"
        ]
      },
      "Split": {
        "purpose": "Two-part content/media layout.",
        "variants": [
          "contentLeft",
          "contentRight",
          "balanced",
          "mediaDominant",
          "contentDominant"
        ]
      },
      "Cluster": {
        "purpose": "Inline grouped items such as buttons, logos, badges, or links.",
        "variants": [
          "start",
          "center",
          "end",
          "between"
        ]
      }
    }
  },
