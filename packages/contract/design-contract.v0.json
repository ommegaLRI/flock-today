{
  "$schema": "https://stitch.dev/schemas/design-contract.v0.json",
  "kind": "StitchDesignContract",
  "version": "0.1.0",
  "name": "Stitch Canonical Campaign Design Contract",
  "definition": "Brand tokens + page grammar + component recipes + safety policies.",
  "hierarchy": [
    "brand",
    "page",
    "section",
    "block",
    "element",
    "token"
  ],
  "coreSections": [
    "Hero",
    "LogoCloud",
    "Problem",
    "Benefits",
    "FeatureGrid",
    "HowItWorks",
    "Testimonials",
    "Stats",
    "Offer",
    "Pricing",
    "FAQ",
    "FinalCTA",
    "Footer"
  ],
  "coreElements": [
    "Heading",
    "Text",
    "Button",
    "Link",
    "Image",
    "Badge",
    "Card",
    "List",
    "Form",
    "Icon"
  ],
  "contentPrimitives": [
    "audience",
    "pain",
    "promise",
    "outcome",
    "mechanism",
    "differentiator",
    "proof",
    "objection",
    "riskReversal",
    "urgency",
    "cta",
    "trust",
    "offer"
  ],
  "safety": {
    "clientFeedback": "comment-only",
    "modelOutput": "untrusted-until-validated",
    "safeDefault": "spec-patch-before-code-patch",
    "publish": "owner-approval-required"
  }
}