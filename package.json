{
  "name": "stitch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source campaign-site migration, design-contract generation, and private site capsule tooling.",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck",
    "eval:bootstrap": "npm run build && node --loader ./tests/evals/stitch-dist-loader.mjs tests/evals/bootstrap-ingestion.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
