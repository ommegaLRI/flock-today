{
  "name": "@flock/capsule",
  "version": "1.0.0",
  "description": "Private, browser-local section editing intelligence for Stitch-generated Astro sites.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "flock": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": "./dist/client.js",
    "./project": {
      "types": "./dist/project.d.ts",
      "import": "./dist/project.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "npm run build && tsc --watch --preserveWatchOutput",
    "test": "npm run build && node --test",
    "check": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "astro": ">=5 <6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "astro": "^5.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@astrojs/compiler": "^4.0.0",
    "@mlc-ai/web-llm": "^0.2.84"
  }
}
